# Required
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Claude model (default shown)
CLAUDE_MODEL=claude-sonnet-4-6

# TTS voice: alloy | echo | fable | onyx | nova | shimmer
TTS_VOICE=onyx

# Target word count for the audiobook script
SCRIPT_WORD_TARGET=400

# Max tokens for Claude's summarization response
SUMMARIZER_MAX_TOKENS=2048

# Web server
HOST=0.0.0.0
PORT=8000

# Directory where CLI saves output MP3s
OUTPUT_DIR=./output
